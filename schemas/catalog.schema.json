{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/varuneaswar/AI-Skills/schemas/catalog.schema.json",
  "title": "AI-Skills Catalog",
  "description": "Schema for catalog/index.json",
  "type": "object",
  "required": ["version", "updated", "assets"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "description": {
      "type": "string"
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "type", "status", "workstream", "tags", "description", "path", "updated"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "title": {
            "type": "string",
            "maxLength": 80
          },
          "type": {
            "type": "string",
            "enum": ["idea", "prompt", "skill", "agent", "workflow", "automation"]
          },
          "status": {
            "type": "string",
            "enum": ["draft", "active", "deprecated"]
          },
          "workstream": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "Workstream ID from workstreams/registry.json. No enum constraint — add new workstreams freely via the registry."
            },
            "minItems": 1
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "description": {
            "type": "string",
            "maxLength": 500
          },
          "path": {
            "type": "string",
            "description": "Relative path from repo root to the asset file"
          },
          "updated": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "delivery_modes": {
            "type": "array",
            "description": "Which delivery modes this asset supports. Omit for ideas.",
            "items": {
              "type": "string",
              "enum": ["copilot-chat", "api-endpoint", "mcp-tool", "copilot-studio", "in-house-llm"]
            }
          },
          "package_ids": {
            "type": "array",
            "description": "IDs of packages that include this asset.",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
