{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/varuneaswar/AI-Skills/schemas/agent.schema.json",
  "title": "Agent",
  "description": "Schema for an AI-Skills agent asset front matter",
  "type": "object",
  "required": ["id", "title", "type", "version", "status", "workstream", "author", "created", "updated", "tags", "llm_compatibility", "description"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "maxLength": 80
    },
    "type": {
      "type": "string",
      "const": "agent"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "deprecated"]
    },
    "workstream": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "Workstream ID from workstreams/registry.json — no enum constraint"
      },
      "minItems": 1
    },
    "author": {
      "type": "string"
    },
    "created": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
      },
      "minItems": 1
    },
    "llm_compatibility": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["gpt-4o", "gpt-4-turbo", "gpt-4", "gpt-3.5-turbo", "claude-3-5-sonnet", "claude-3-opus", "claude-3-haiku", "gemini-1.5-pro", "gemini-1.5-flash", "azure-openai-gpt-4o", "copilot-gpt-4o", "all"]
      },
      "minItems": 1
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "security_classification": {
      "type": "string",
      "enum": ["public", "internal", "confidential"],
      "default": "internal"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "description"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "description": { "type": "string" },
          "required": { "type": "boolean" }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "description"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "security_notes": {
      "type": "string",
      "description": "Required for confidential agents. Describe data handling and access scope."
    }
  }
}
