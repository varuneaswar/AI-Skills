{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/varuneaswar/AI-Skills/schemas/workstream-registry.schema.json",
  "title": "Workstream Registry",
  "description": "Schema for workstreams/registry.json. This is the single source of truth for all registered work streams.",
  "type": "object",
  "required": ["version", "updated", "workstreams"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "description": {
      "type": "string"
    },
    "adding_new_workstream": {
      "type": "string"
    },
    "workstreams": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "description", "path", "status"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
            "description": "Kebab-case identifier used in asset front matter and folder names"
          },
          "label": {
            "type": "string",
            "description": "Human-readable display name for the portal"
          },
          "description": {
            "type": "string",
            "maxLength": 300
          },
          "path": {
            "type": "string",
            "description": "Relative path from repo root to the work stream folder"
          },
          "owner": {
            "type": "string",
            "description": "GitHub username or team name responsible for this work stream"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "status": {
            "type": "string",
            "enum": ["active", "deprecated", "planned"],
            "description": "active = fully supported, planned = folder reserved but not yet populated"
          }
        }
      }
    }
  }
}
