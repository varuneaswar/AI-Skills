{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/varuneaswar/AI-Skills/schemas/idea.schema.json",
  "title": "Idea",
  "description": "Schema for an AI-Skills idea asset front matter",
  "type": "object",
  "required": ["id", "title", "type", "version", "status", "workstream", "author", "created", "updated", "tags", "description"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Globally unique kebab-case identifier"
    },
    "title": {
      "type": "string",
      "maxLength": 80,
      "description": "Human-readable title"
    },
    "type": {
      "type": "string",
      "const": "idea"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version string"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "deprecated"]
    },
    "workstream": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["architects", "capacity-management", "developers", "performance-engineers", "sre", "system-designers", "testers", "shared"]
      },
      "minItems": 1
    },
    "author": {
      "type": "string",
      "description": "GitHub username of the original author"
    },
    "created": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO 8601 date"
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO 8601 date"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
      },
      "minItems": 1
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "security_classification": {
      "type": "string",
      "enum": ["public", "internal", "confidential"],
      "default": "internal"
    }
  }
}
